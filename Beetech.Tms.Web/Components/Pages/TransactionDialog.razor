@using Microsoft.AspNetCore.Components.Authorization
@using Microsoft.Extensions.Localization
@inject IStringLocalizer<App> L
@inject TmsService TmsService
@inject NotificationService NotificationService
@inject DialogService DialogService
@inject AuthenticationStateProvider AuthenticationStateProvider

<RadzenStack Gap="1rem">
    @if (transaction == null)
    {
        <RadzenProgressBar Value="100" ShowValue="false" Mode="ProgressBarMode.Indeterminate" />
    }
    else
    {
        <RadzenTemplateForm TItem="Transaction" Data="@transaction" Submit="@OnSubmit">
            <RadzenStack Gap="1rem">
                <RadzenRow>
                    <RadzenColumn Size="12" SizeMD="6">
                        <RadzenFieldset Text="@L["BasicInfo"]">
                            <RadzenStack Gap="0.5rem">
                                <RadzenLabel Text="@L["TransactionDate"]" Component="TransactionDate" />
                                <RadzenDatePicker Name="TransactionDate" @bind-Value="@transaction.TransactionDate" DateFormat="d" style="width: 100%;" />
                                
                                <RadzenLabel Text="@L["FromLocation"]" Component="FromLocationId" />
                                <RadzenDropDown Name="FromLocationId" Data="@locations" TextProperty="Name" ValueProperty="Id" 
                                               @bind-Value="@transaction.FromLocationId" style="width: 100%;" AllowFiltering="true" />
                                
                                <RadzenLabel Text="@L["ToLocation"]" Component="ToLocationId" />
                                <RadzenDropDown Name="ToLocationId" Data="@locations" TextProperty="Name" ValueProperty="Id" 
                                               @bind-Value="@transaction.ToLocationId" style="width: 100%;" AllowFiltering="true" />

                                @if (transaction.Type == TransactionType.Delivery || transaction.Type == TransactionType.InternalTransfer)
                                {
                                    <RadzenLabel Text="@L["Department"]" Component="DepartmentId" />
                                    <RadzenDropDown Name="DepartmentId" Data="@departments" TextProperty="Name" ValueProperty="Id" 
                                                   @bind-Value="@transaction.DepartmentId" style="width: 100%;" AllowFiltering="true" />
                                }
                                
                                <RadzenLabel Text="@L["Notes"]" Component="Notes" />
                                <RadzenTextArea Name="Notes" @bind-Value="@transaction.Notes" style="width: 100%;" />
                            </RadzenStack>
                        </RadzenFieldset>
                    </RadzenColumn>
                    
                    <RadzenColumn Size="12" SizeMD="6">
                        <RadzenFieldset Text="@L["ScanItems"]">
                            <RadzenStack Gap="1rem">
                                <RadzenStack Orientation="Orientation.Horizontal" AlignItems="AlignItems.Center" Gap="0.5rem">
                                    <RadzenTextBox Placeholder="@L["ScanBarcodeRFID"]" @bind-Value="@newRfid" style="flex: 1" 
                                                  @onkeyup="@(async (e) => { if (e.Key == "Enter") await AddItemByRfid(); })" />
                                    <RadzenButton Icon="add" Text="@L["Add"]" Click="@AddItemByRfid" Disabled="@string.IsNullOrEmpty(newRfid)" />
                                </RadzenStack>
                                
                                <RadzenDataGrid Data="@transaction.Items" TItem="TransactionItem" style="height: 300px">
                                    <Columns>
                                        <RadzenDataGridColumn Title="@L["Actions"]" Width="60px">
                                            <Template Context="item">
                                                <RadzenButton Icon="close" ButtonStyle="ButtonStyle.Danger" Size="ButtonSize.Small" 
                                                              Click="@(() => RemoveItem(item))" />
                                            </Template>
                                        </RadzenDataGridColumn>
                                    </Columns>
                                </RadzenDataGrid>
                                <RadzenText Text="@(string.Format(L["TotalItemsCount"], transaction.Items.Count))" TextStyle="TextStyle.Subtitle2" />
                            </RadzenStack>
                        </RadzenFieldset>
                    </RadzenColumn>
                </RadzenRow>
                
                <RadzenStack Orientation="Orientation.Horizontal" JustifyContent="JustifyContent.End" Gap="0.5rem">
                    <RadzenButton ButtonType="ButtonType.Submit" Text="@L["Save"]" Icon="save" ButtonStyle="ButtonStyle.Primary" />
                    <RadzenButton Text="@L["Cancel"]" Click="@(() => DialogService.Close(false))" ButtonStyle="ButtonStyle.Light" />
                </RadzenStack>
            </RadzenStack>
        </RadzenTemplateForm>
    }
</RadzenStack>

@code {
    [Parameter] public TransactionType? Type { get; set; }
    [Parameter] public int? TransactionId { get; set; }

    Transaction transaction = null!;
    IEnumerable<Location> locations = new List<Location>();
    IEnumerable<Department> departments = new List<Department>();
    string? newRfid;

    protected override async Task OnInitializedAsync()
    {
        locations = await TmsService.GetLocationsAsync();
        departments = await TmsService.GetDepartmentsAsync();

        if (TransactionId.HasValue)
        {
            transaction = await TmsService.GetTransactionByIdAsync(TransactionId.Value);
        }
        else
        {
            transaction = new Transaction
            {
                Type = Type ?? TransactionType.Delivery,
                TransactionDate = DateTime.Now,
                Items = new List<TransactionItem>()
            };
        }
    }

    async Task AddItemByRfid()
    {
        if (string.IsNullOrEmpty(newRfid)) return;
        
        var item = await TmsService.GetItemByRfidAsync(newRfid);
        if (item == null)
        {
            NotificationService.Notify(new NotificationMessage { Severity = NotificationSeverity.Warning, Summary = L["Warning"], Detail = string.Format(L["RFIDTagNotFound"], newRfid) });
            newRfid = null;
            return;
        }

        if (transaction.Items.Any(i => i.TextileItemId == item.Id))
        {
            NotificationService.Notify(new NotificationMessage { Severity = NotificationSeverity.Info, Summary = L["Info"], Detail = L["ItemAlreadyInList"] });
            newRfid = null;
            return;
        }

        transaction.Items.Add(new TransactionItem
        {
            TextileItemId = item.Id
        });

        newRfid = null;
        StateHasChanged();
    }

    void RemoveItem(TransactionItem item)
    {
        transaction.Items.Remove(item);
    }

    async Task OnSubmit()
    {
        if (!transaction.Items.Any())
        {
            NotificationService.Notify(new NotificationMessage { Severity = NotificationSeverity.Error, Summary = L["Error"], Detail = L["PleaseScanAtLeastOneItem"] });
            return;
        }

        if (transaction.Type != TransactionType.InternalTransfer && transaction.FromLocationId == transaction.ToLocationId)
        {
            NotificationService.Notify(new NotificationMessage { Severity = NotificationSeverity.Error, Summary = L["Error"], Detail = L["LocationsMustBeDifferent"] });
            return;
        }

        var authState = await AuthenticationStateProvider.GetAuthenticationStateAsync();
        var user = authState.User;
        // In a real app, we'd get the user ID here. For now, we'll let the service handle it or use a default.

        var success = await TmsService.UpsertTransactionAsync(transaction);
        if (success)
        {
            NotificationService.Notify(new NotificationMessage { Severity = NotificationSeverity.Success, Summary = L["Success"], Detail = L["TransactionSaved"] });
            DialogService.Close(true);
        }
    }
}
