@using Beetech.Tms.Core.Models
@using Beetech.Tms.Web.Services
@inject TmsService TmsService
@inject DialogService DialogService
@inject NotificationService NotificationService
@inject IStringLocalizer<App> L

<RadzenTemplateForm TItem="TextileItem" Data="@Item" Submit="@OnSubmit">
    <RadzenStack Gap="1rem">
        <RadzenFieldset Text="@L["ItemDetails"]">
            <RadzenStack Gap="1rem">
                <div class="row">
                    <div class="col-md-4 rz-text-align-right">
                        <RadzenLabel Text="@L["Category"]" Component="CategoryId" />
                    </div>
                    <div class="col-md-8">
                        <RadzenDropDown style="display: block; width: 100%;" TValue="int" Data="@categories" 
                                        TextProperty="Name" ValueProperty="Id" @bind-Value="@Item.CategoryId" Name="CategoryId" />
                        <RadzenRequiredValidator Component="CategoryId" DefaultValue="0" Text="@L["CategoryRequired"]" />
                    </div>
                </div>
                <div class="row">
                    <div class="col-md-4 rz-text-align-right">
                        <RadzenLabel Text="@L["Status"]" Component="Status" />
                    </div>
                    <div class="col-md-8">
                        <RadzenDropDown style="display: block; width: 100%;" TValue="ItemStatus" 
                                        Data="@(Enum.GetValues(typeof(ItemStatus)))" @bind-Value="@Item.Status" Name="Status" />
                    </div>
                </div>
                <div class="row">
                    <div class="col-md-4 rz-text-align-right">
                        <RadzenLabel Text="@L["Location"]" Component="CurrentLocationId" />
                    </div>
                    <div class="col-md-8">
                        <RadzenDropDown style="display: block; width: 100%;" TValue="int?" Data="@locations" 
                                        TextProperty="Name" ValueProperty="Id" @bind-Value="@Item.CurrentLocationId" Name="CurrentLocationId" 
                                        AllowClear="true" Placeholder="@L["SelectLocation"]" />
                    </div>
                </div>
                <div class="row">
                    <div class="col-md-4 rz-text-align-right">
                        <RadzenLabel Text="@L["Department"]" Component="CurrentDepartmentId" />
                    </div>
                    <div class="col-md-8">
                        <RadzenDropDown style="display: block; width: 100%;" TValue="int?" Data="@departments" 
                                        TextProperty="Name" ValueProperty="Id" @bind-Value="@Item.CurrentDepartmentId" Name="CurrentDepartmentId" 
                                        AllowClear="true" Placeholder="@L["SelectDepartment"]" />
                    </div>
                </div>
                <div class="row">
                    <div class="col-md-4 rz-text-align-right">
                        <RadzenLabel Text="@L["WashCount"]" Component="WashCount" />
                    </div>
                    <div class="col-md-8">
                        <RadzenNumeric style="display: block; width: 100%;" @bind-Value="@Item.WashCount" Name="WashCount" Min="0" />
                    </div>
                </div>
            </RadzenStack>
        </RadzenFieldset>
        <RadzenStack Orientation="Orientation.Horizontal" JustifyContent="JustifyContent.End" Gap="0.5rem">
            <RadzenButton ButtonType="ButtonType.Submit" Text="@L["Save"]" Icon="save" />
            <RadzenButton ButtonStyle="ButtonStyle.Light" Text="@L["Cancel"]" Click="@((args) => DialogService.Close(false))" />
        </RadzenStack>
    </RadzenStack>
</RadzenTemplateForm>

@code {
    [Parameter] public TextileItem Item { get; set; } = new();
    
    List<Category> categories = new();
    List<Location> locations = new();
    List<Department> departments = new();

    protected override async Task OnInitializedAsync()
    {
        categories = await TmsService.GetCategoriesAsync();
        locations = await TmsService.GetLocationsAsync();
        departments = await TmsService.GetDepartmentsAsync();
    }

    async Task OnSubmit()
    {
        Item.LastScanAt = DateTime.UtcNow;
        var success = await TmsService.UpsertItemAsync(Item);
        if (success)
        {
            NotificationService.Notify(new NotificationMessage { Severity = NotificationSeverity.Success, Summary = L["Success"], Detail = L["ItemRegisteredSuccessfully"] });
            DialogService.Close(true);
        }
        else
        {
            NotificationService.Notify(new NotificationMessage { Severity = NotificationSeverity.Error, Summary = L["Error"], Detail = L["FailedSaveItem"] });
        }
    }
}
