@page "/locations"
@attribute [Microsoft.AspNetCore.Authorization.Authorize(Roles = "Admin,Manager")]
@inject TmsService TmsService
@inject NotificationService NotificationService
@inject DialogService DialogService

<PageTitle>Locations - Beetech TMS</PageTitle>

<RadzenStack Orientation="Orientation.Horizontal" AlignItems="AlignItems.Center" JustifyContent="JustifyContent.SpaceBetween" class="rz-mb-4">
    <RadzenText Text="Locations" TextStyle="TextStyle.H4" class="rz-m-0" />
    <RadzenButton Icon="add_circle_outline" Text="Add Location" Click="@OnAddLocation" />
</RadzenStack>

<RadzenDataGrid @ref="grid" AllowFiltering="true" FilterMode="FilterMode.Advanced" AllowColumnResize="true" AllowAlternatingRows="false"
                FilterCaseSensitivity="FilterCaseSensitivity.CaseInsensitive" AllowSorting="true" PageSize="10" AllowPaging="true" 
                PagerHorizontalAlign="HorizontalAlign.Left" ShowPagingSummary="true"
                Data="@locations" TItem="Location" ColumnWidth="300px">
    <Columns>
        <RadzenDataGridColumn Property="Id" Title="ID" Width="80px" />
        <RadzenDataGridColumn Property="Name" Title="Name" />
        <RadzenDataGridColumn Title="Actions" Sortable="false" Filterable="false" Width="120px" Frozen="true">
            <Template Context="location">
                <RadzenStack Orientation="Orientation.Horizontal" Gap="0.5rem">
                    <RadzenButton Icon="edit" ButtonStyle="ButtonStyle.Light" Variant="Variant.Flat" Size="ButtonSize.Medium" 
                                  Click="@(() => EditLocation(location))" @onclick:stopPropagation="true" />
                    <RadzenButton Icon="delete" ButtonStyle="ButtonStyle.Danger" Variant="Variant.Flat" Size="ButtonSize.Medium" 
                                  Click="@(() => OnDeleteLocation(location))" @onclick:stopPropagation="true" />
                </RadzenStack>
            </Template>
        </RadzenDataGridColumn>
    </Columns>
</RadzenDataGrid>

@code {
    RadzenDataGrid<Location> grid = null!;
    IEnumerable<Location> locations = new List<Location>();

    protected override async Task OnInitializedAsync()
    {
        await LoadData();
    }

    async Task LoadData()
    {
        locations = await TmsService.GetLocationsAsync();
    }

    async Task OnAddLocation()
    {
        await EditLocation(new Location());
    }

    async Task EditLocation(Location location)
    {
        var result = await DialogService.OpenAsync<LocationEditDialog>(location.Id == 0 ? "Add Location" : "Edit Location",
            new Dictionary<string, object> { { "Location", location } }, new DialogOptions());

        if (result == true)
        {
            await LoadData();
            if (grid != null) await grid.Reload();
        }
    }

    async Task OnDeleteLocation(Location location)
    {
        var confirm = await DialogService.Confirm($"Are you sure you want to delete location '{location.Name}'?", "Delete Location");
        if (confirm == true)
        {
            var success = await TmsService.DeleteLocationAsync(location.Id);
            if (success)
            {
                NotificationService.Notify(new NotificationMessage { Severity = NotificationSeverity.Success, Summary = "Success", Detail = "Location deleted" });
                await LoadData();
                if (grid != null) await grid.Reload();
            }
        }
    }
}
