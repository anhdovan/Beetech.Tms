<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="clr-namespace:Beetech.Tms.Desktop.ViewModels;assembly=Beetech.Tms.Desktop"
             xmlns:material="using:Material.Icons.Avalonia"
             x:Class="Beetech.Tms.Desktop.Views.TagRegistrationView"
             x:DataType="vm:TagRegistrationViewModel"
             Background="White">

    <Border Background="#F3F4F6">
        <ScrollViewer HorizontalScrollBarVisibility="Disabled" VerticalScrollBarVisibility="Auto">
            <Grid RowDefinitions="Auto,Auto,Auto" HorizontalAlignment="Stretch" Margin="20" VerticalAlignment="Top">
            <!-- Header Section -->
            <Border Grid.Row="0" Background="White" CornerRadius="12" Padding="25" Margin="0,0,0,15" BoxShadow="0 2 10 0 #11000000">
                <StackPanel Spacing="15">
                    <StackPanel Spacing="5">
                        <TextBlock Text="{Binding L[BulkItemRegistration]}" FontSize="28" FontWeight="Heavy" Foreground="{StaticResource TmsBlueBrush}"/>
                        <TextBlock Text="{Binding L[InitializeMultipleTags]}" Foreground="#6B7280" FontSize="13"/>
                    </StackPanel>
                    
                    <Separator Background="#E5E7EB"/>
                    
                    <Grid ColumnDefinitions="*,*,*">
                        <StackPanel Spacing="8" Margin="0,0,10,0">
                            <TextBlock Text="{Binding L[Category]}" FontWeight="SemiBold" FontSize="12"/>
                            <ComboBox ItemsSource="{Binding Categories}" SelectedItem="{Binding SelectedCategory}" HorizontalAlignment="Stretch" CornerRadius="8">
                                <ComboBox.ItemTemplate>
                                    <DataTemplate>
                                        <TextBlock Text="{Binding Name}"/>
                                    </DataTemplate>
                                </ComboBox.ItemTemplate>
                            </ComboBox>
                        </StackPanel>
                        
                        <StackPanel Grid.Column="1" Spacing="8" Margin="10,0,10,0">
                            <TextBlock Text="{Binding L[InitialLocation]}" FontWeight="SemiBold" FontSize="12"/>
                            <ComboBox ItemsSource="{Binding Locations}" SelectedItem="{Binding SelectedLocation}" HorizontalAlignment="Stretch" CornerRadius="8">
                                <ComboBox.ItemTemplate>
                                    <DataTemplate>
                                        <TextBlock Text="{Binding Name}"/>
                                    </DataTemplate>
                                </ComboBox.ItemTemplate>
                            </ComboBox>
                        </StackPanel>

                        <StackPanel Grid.Column="2" Spacing="8" Margin="10,0,0,0">
                            <TextBlock Text="{Binding L[Department]}" FontWeight="SemiBold" FontSize="12"/>
                            <ComboBox ItemsSource="{Binding Departments}" SelectedItem="{Binding SelectedDepartment}" HorizontalAlignment="Stretch" CornerRadius="8">
                                <ComboBox.ItemTemplate>
                                    <DataTemplate>
                                        <TextBlock Text="{Binding Name}"/>
                                    </DataTemplate>
                                </ComboBox.ItemTemplate>
                            </ComboBox>
                        </StackPanel>
                    </Grid>
                </StackPanel>
            </Border>

            <!-- Grid Section -->
            <Border Grid.Row="1" Background="White" CornerRadius="12" Padding="0" BoxShadow="0 2 10 0 #11000000">
                <Grid RowDefinitions="Auto,*">
                    <Border Background="#F9FAFB" CornerRadius="12,12,0,0" Padding="15,10">
                        <Grid ColumnDefinitions="*,Auto">
                            <TextBlock Text="{Binding L[ScannedItems]}" VerticalAlignment="Center" FontWeight="Bold" Foreground="#374151"/>
                            <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="15">
                                <TextBlock Text="{Binding TotalScanned, StringFormat='Total: {0}'}" VerticalAlignment="Center" Foreground="#6B7280" FontSize="12"/>
                                <TextBlock Text="{Binding TotalSuccess, StringFormat='Success: {0}'}" VerticalAlignment="Center" Foreground="#10B981" FontSize="12" FontWeight="Bold"/>
                            </StackPanel>
                        </Grid>
                    </Border>
                    
                    <DataGrid Grid.Row="1" ItemsSource="{Binding ScanResults}" 
                              AutoGenerateColumns="False" IsReadOnly="True"
                              GridLinesVisibility="All" BorderThickness="0"
                              Background="Transparent" MinHeight="200" MaxHeight="500">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="{Binding L[OriginalEPC]}" Binding="{Binding Epc}" Width="*" />
                            <DataGridTextColumn Header="{Binding L[NewRFIDCode]}" Binding="{Binding RfidCode}" Width="*" />
                            <DataGridTemplateColumn Header="{Binding L[StatusHeader]}" Width="120">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <Border Padding="8,4" CornerRadius="4" HorizontalAlignment="Center" VerticalAlignment="Center"
                                                Background="{Binding Status, Converter={StaticResource StatusToBrushConverter}}">
                                            <TextBlock Text="{Binding Status}" Foreground="White" FontSize="11" FontWeight="Bold"/>
                                        </Border>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>
                        </DataGrid.Columns>
                    </DataGrid>
                </Grid>
            </Border>

            <!-- Actions Section -->
            <Border Grid.Row="2" Background="White" CornerRadius="12" Padding="20" Margin="0,15,0,0" BoxShadow="0 2 10 0 #11000000">
                <Grid ColumnDefinitions="Auto,*,Auto">

                    <StackPanel Grid.Column="1" VerticalAlignment="Center" Margin="20,0">
                        <TextBlock Text="{Binding StatusMessage}" HorizontalAlignment="Center" FontWeight="SemiBold" 
                                   Foreground="{StaticResource TmsBlueBrush}"/>
                        <ProgressBar IsIndeterminate="True" IsVisible="{Binding IsBusy}" Height="2" Margin="0,5,0,0"/>
                    </StackPanel>

                    <Button Grid.Column="2" Command="{Binding RegisterBulkCommand}"
                            Background="{StaticResource TmsOrangeBrush}" Foreground="White" 
                            CornerRadius="8" Padding="25,12" IsEnabled="{Binding !IsScanning}">
                        <StackPanel Orientation="Horizontal" Spacing="10">
                            <material:MaterialIcon Kind="ContentSaveAll" Width="20" Height="20"/>
                            <TextBlock Text="{Binding L[RegisterApplyTags]}" FontWeight="Bold" FontSize="15"/>
                        </StackPanel>
                    </Button>
                </Grid>
            </Border>
        </Grid>
        </ScrollViewer>
    </Border>
</UserControl>
