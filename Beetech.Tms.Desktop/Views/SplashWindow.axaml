<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="clr-namespace:Beetech.Tms.Desktop.ViewModels;assembly=Beetech.Tms.Desktop"
        xmlns:material="using:Material.Icons.Avalonia"
        xmlns:services="using:Beetech.Tms.Desktop.Services"
        x:Class="Beetech.Tms.Desktop.Views.SplashWindow"
        x:DataType="services:LanguageManager"
        Title="SplashWindow"
        Width="500" Height="300"
        SystemDecorations="None"
        WindowStartupLocation="CenterScreen"
        Topmost="True"
        Background="Transparent"
        TransparencyLevelHint="Transparent">

    <Border Background="White" CornerRadius="20" BoxShadow="0 10 30 0 #44000000" Margin="20">
        <Grid>
            <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center" Spacing="20">
                <Image Source="/Assets/logo.png" Width="120" Height="120"/>
                
                <StackPanel Spacing="5">
                    <TextBlock Text="{Binding [AppTitleShort]}" 
                               FontSize="28" 
                               FontWeight="Bold" 
                               Foreground="{StaticResource TmsBlueBrush}"
                               HorizontalAlignment="Center"/>
                    <TextBlock Text="{Binding [AppSubtitle]}" 
                               FontSize="14" 
                               Foreground="#888888"
                               HorizontalAlignment="Center"/>
                </StackPanel>

                <ProgressBar x:Name="LoadProgress" 
                             Width="200" 
                             Height="4" 
                             IsIndeterminate="True"
                             Background="#EEEEEE"
                             Foreground="{StaticResource TmsBlueBrush}"
                             Margin="0,20,0,0"/>
            </StackPanel>
            
            <TextBlock Text="{Binding [VersionLabel]}" 
                       FontSize="10" 
                       Foreground="#CCCCCC" 
                       HorizontalAlignment="Right" 
                       VerticalAlignment="Bottom"
                       Margin="15"/>
        </Grid>
    </Border>
</Window>
