<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/card_view"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginHorizontal="8dp"
    android:layout_marginVertical="4dp"
    app:cardCornerRadius="12dp"
    app:cardElevation="2dp"
    app:strokeWidth="1dp"
    app:strokeColor="?attr/colorOutlineVariant">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:padding="12dp"
        android:gravity="center_vertical">

        <ImageView
            android:id="@+id/image_status"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:padding="8dp"
            android:src="@android:drawable/ic_dialog_info"
            app:tint="?attr/colorPrimary" />

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:layout_marginStart="12dp"
            android:orientation="vertical">

            <TextView
                android:id="@+id/text_file_code"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="FILE-001"
                android:textAppearance="?attr/textAppearanceTitleMedium"
                android:textColor="?attr/colorPrimary" />

            <TextView
                android:id="@+id/text_title"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Hồ sơ khách hàng A"
                android:textAppearance="?attr/textAppearanceBodyMedium"
                android:ellipsize="end"
                android:maxLines="1" />

            <TextView
                android:id="@+id/text_customer"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Khách hàng: Nguyễn Văn A"
                android:textAppearance="?attr/textAppearanceBodySmall"
                android:alpha="0.7" />

            <TextView
                android:id="@+id/text_rfid_code"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="2dp"
                android:text="3001..."
                android:fontFamily="monospace"
                android:textSize="11sp"
                android:textColor="?attr/colorPrimary"
                android:background="?attr/colorSurfaceVariant"
                android:paddingHorizontal="4dp"
                android:paddingVertical="1dp" />
        </LinearLayout>

        <ImageButton
            android:id="@+id/btn_locate_rfid"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:contentDescription="Tìm kiếm RFID"
            android:padding="8dp"
            android:src="@android:drawable/ic_menu_search"
            app:tint="?attr/colorPrimary" />

        <ImageButton
            android:id="@+id/btn_write_rfid"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:contentDescription="Ghi thẻ RFID"
            android:padding="8dp"
            android:src="@android:drawable/ic_menu_edit"
            app:tint="?attr/colorPrimary" />

        <ImageButton
            android:id="@+id/btn_return"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:contentDescription="Trả hồ sơ"
            android:padding="8dp"
            android:src="@android:drawable/ic_menu_revert"
            android:visibility="gone"
            app:tint="?attr/colorPrimary" />

        <ImageButton
            android:id="@+id/btn_loan_request"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:contentDescription="Mượn hồ sơ"
            android:padding="8dp"
            android:src="@android:drawable/ic_menu_today"
            android:visibility="gone"
            app:tint="?attr/colorPrimary" />

        <CheckBox
            android:id="@+id/checkbox_select"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:visibility="gone" />

    </LinearLayout>

</com.google.android.material.card.MaterialCardView>
